<Window x:Class="AppLimit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppLimit"
        Width="980"
        Height="700"
        MinWidth="900"
        MinHeight="650"
        Background="#14141F"
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- ===================== BRUSHES ===================== -->

        <LinearGradientBrush x:Key="BgGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#14141F" Offset="0"/>
            <GradientStop Color="#1B1B2F" Offset="0.55"/>
            <GradientStop Color="#1A1730" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6366F1" Offset="0"/>
            <GradientStop Color="#8B5CF6" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#4F46E5" Offset="0"/>
            <GradientStop Color="#7C3AED" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="CardBrush" Color="#23233A"/>
        <SolidColorBrush x:Key="CardBrushHover" Color="#2B2B47"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerBrushHover" Color="#DC2626"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#33334D"/>

        <!-- ===================== EFFECTS ===================== -->

        <DropShadowEffect x:Key="CardShadow" Color="#000000" Direction="270"
                           ShadowDepth="6" BlurRadius="18" Opacity="0.35"/>

        <DropShadowEffect x:Key="HeaderShadow" Color="#4F46E5" Direction="270"
                           ShadowDepth="0" BlurRadius="30" Opacity="0.5"/>

        <!-- ===================== BUTTON STYLES ===================== -->

        <Style x:Key="BasePillButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryPillButton" TargetType="Button" BasedOn="{StaticResource BasePillButton}">
            <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
        </Style>

        <Style x:Key="DangerPillButton" TargetType="Button" BasedOn="{StaticResource BasePillButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        </Style>

    </Window.Resources>

    <!-- Root: background layer + content layer -->
    <Grid>

        <Grid.Background>
            <StaticResource ResourceKey="BgGradient"/>
        </Grid.Background>

        <!-- Decorative blurred glow shapes (ganti dengan ImageBrush jika ingin pakai asset gambar,
             contoh: <Grid.Background><ImageBrush ImageSource="/Assets/bg.png" Stretch="UniformToFill" Opacity="0.25"/></Grid.Background> -->
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="340" Height="340" Canvas.Top="-140" Canvas.Right="-100" Fill="#6366F1" Opacity="0.18">
                <Ellipse.Effect>
                    <BlurEffect Radius="90"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="260" Height="260" Canvas.Bottom="-90" Canvas.Left="-80" Fill="#8B5CF6" Opacity="0.14">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===================== HEADER ===================== -->
            <Border Grid.Row="0"
                    Background="{StaticResource HeaderGradient}"
                    CornerRadius="18"
                    Padding="26"
                    Margin="0,0,0,22"
                    Effect="{StaticResource HeaderShadow}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock
                            Text="🧑🏻‍🚀AppLimiter"
                            FontSize="34"
                            FontWeight="Bold"/>

                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="15"
                            Foreground="#E0E7FF"
                            Text="Stay productive. Control your App usage time."/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#33FFFFFF"
                            CornerRadius="30"
                            Width="56" Height="56"
                            VerticalAlignment="Center">
                        <TextBlock Text="⏱" FontSize="26"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ===================== RULE LIST ===================== -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding Rules}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Background="{StaticResource CardBrush}"
                                CornerRadius="16"
                                Padding="18"
                                Margin="0,0,14,16"
                                Effect="{StaticResource CardShadow}">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon badge -->
                                    <Border Grid.Column="0"
                                            Width="54" Height="54"
                                            CornerRadius="14"
                                            Background="{StaticResource AccentGradient}"
                                            VerticalAlignment="Top"
                                            Margin="0,2,16,0">
                                        <TextBlock Text="🕹"
                                                   FontSize="24"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Informasi -->
                                    <StackPanel Grid.Column="1">

                                        <TextBlock
                                            FontSize="20"
                                            FontWeight="Bold"
                                            TextWrapping="Wrap"
                                            Text="{Binding Name}"/>

                                        <TextBlock
                                            Margin="0,3,0,12"
                                            FontSize="13"
                                            Foreground="#9CA3AF"
                                            Text="{Binding ProcessName}"/>

                                        <Border Background="#1E3A2E"
                                                CornerRadius="8"
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,10">
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                FontSize="13"
                                                Foreground="#4ADE80"
                                                Text="{Binding StatusText}"/>
                                        </Border>

                                        <TextBlock
                                            FontSize="14"
                                            Foreground="#D1D5DB"
                                            Text="{Binding TimeLimit, StringFormat=⏳ Limit : {0} menit}"/>

                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontSize="14"
                                            Foreground="#D1D5DB"
                                            Text="{Binding UsageText, StringFormat=📊 Digunakan : {0}}"/>

                                        <CheckBox
                                            Margin="0,14,0,0"
                                            Content="{Binding EnabledText}"
                                            Foreground="#E5E7EB"
                                            IsChecked="{Binding Enabled}"
                                            Command="{Binding DataContext.ToggleRuleCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>

                                    </StackPanel>

                                    <!-- Tombol -->
                                    <StackPanel
                                        Grid.Column="2"
                                        VerticalAlignment="Center">

                                        <Button
                                            Width="96"
                                            Height="36"
                                            Margin="0,0,0,10"
                                            Content="✏ Edit"
                                            Style="{StaticResource PrimaryPillButton}"
                                            Command="{Binding DataContext.EditRuleCommand,
                          RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>

                                        <Button
                                            Width="96"
                                            Height="36"
                                            Content="🗑 Delete"
                                            Style="{StaticResource DangerPillButton}"
                                            Command="{Binding DataContext.DeleteRuleCommand,
                          RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>

                                    </StackPanel>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

            <!-- ===================== ADD BUTTON ===================== -->
            <StackPanel Grid.Row="2"
                        Margin="0,20,0,0">

                <Button
                    Height="50"
                    FontSize="16"
                    Content="＋ Tambah Aplikasi"
                    Style="{StaticResource PrimaryPillButton}"
                    Command="{Binding AddRuleCommand}">
                    <Button.Effect>
                        <DropShadowEffect Color="#6366F1" Direction="270"
                                           ShadowDepth="0" BlurRadius="20" Opacity="0.5"/>
                    </Button.Effect>
                </Button>

            </StackPanel>

        </Grid>

    </Grid>
</Window>
