<Window x:Class="PlayLimit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PlayLimit"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0"
                  ItemsSource="{Binding Rules}"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Nama"
                                    Binding="{Binding Name}"/>

                <DataGridTextColumn Header="Process"
                                    Binding="{Binding ProcessName}"/>

                <DataGridTextColumn Header="Limit"
                                    Binding="{Binding TimeLimit}"/>

                <DataGridCheckBoxColumn Header="Aktif"
                                        Binding="{Binding Enabled}"/>

            </DataGrid.Columns>

        </DataGrid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button Width="100"
                    Height="35"
                    Content="Tambah"
                    Command="{Binding AddRuleCommand}"/>

        </StackPanel>

    </Grid>
</Window>