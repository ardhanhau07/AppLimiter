<Window x:Class="PlayLimit.Views.RuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tambah Program"
        Height="350"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Nama -->
        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Text="Nama"/>

        <TextBox Grid.Row="0"
                 Grid.Column="1"
                 Margin="5"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- EXE -->
        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Text="Executable"/>

        <TextBox
            Grid.Row="1"
            Grid.Column="1"
            Margin="5"
            IsReadOnly="True"
            Text="{Binding ExePath}"/>

        <Button
            Grid.Row="1"
            Grid.Column="2"
            Margin="5"
            Width="80"
            Content="Browse"
            Command="{Binding BrowseCommand}"/>

        <!-- Process -->
        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Text="Process"/>

        <TextBox Grid.Row="2"
                 Grid.Column="1"
                 Margin="5"
                 IsReadOnly="True"
                 Text="{Binding ProcessName}"/>

        <!-- Limit -->
        <TextBox
            Grid.Row="3"
            Grid.Column="1"
            Margin="5"
            Width="120"
            HorizontalAlignment="Left"
            Text="{Binding TimeLimit}"/>

        <TextBlock
            Grid.Row="3"
            Grid.Column="2"
            Margin="10,0,0,0"
            VerticalAlignment="Center"
            Text="menit"/>

        <!-- Aktif -->
        <CheckBox
            Grid.Row="4"
            Grid.Column="1"
            Margin="5"
            Content="Aktif"
            IsChecked="{Binding Enabled}"/>

        <!-- Tombol -->
        <StackPanel Grid.Row="5"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Width="90"
                    Margin="5"
                    Content="Simpan"
                    Command="{Binding SaveCommand}"/>

            <Button Width="90"
                    Margin="5"
                    Content="Batal"
                    Click="Cancel_Click"/>

        </StackPanel>

    </Grid>

</Window>